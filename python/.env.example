# Scouter backend URL (self-hosted or cloud)
SCOUTER_BACKEND_URL=http://localhost:8000

# Your Scouter API key (from the dashboard)
SCOUTER_API_KEY=your-api-key-here

# Optional: Azure OpenAI (for test_deployed.py)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/v1
AZURE_OPENAI_KEY=your-azure-openai-key
