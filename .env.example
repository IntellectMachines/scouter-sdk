# =============================================================================
# scouter-sdk — CI/CD secrets
# =============================================================================
# This file documents the secrets the GitHub Actions workflow
# (.github/workflows/publish.yml) expects. They are NOT loaded at runtime;
# register them in GitHub under:
#   Settings > Secrets and variables > Actions > New repository secret
#
# The per-package runtime env vars (SCOUTER_API_KEY, etc.) live in
# python/.env.example and node/.env.example respectively.
# -----------------------------------------------------------------------------

# PyPI API token used by `twine upload` to publish the `scouter-ai` package.
# Create at: https://pypi.org/manage/account/token/  (scope: project scouter-ai)
# The value must start with "pypi-".
PYPI_API_TOKEN=pypi-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# npm automation token used by `npm publish` to publish `@scouter/core`.
# Create at: https://www.npmjs.com/settings/<user>/tokens  (type: Automation)
# TODO: ensure the token's owner has publish rights to the @scouter scope.
NPM_TOKEN=npm_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
